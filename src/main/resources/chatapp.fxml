<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.*?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.text.*?>

<AnchorPane xmlns="http://javafx.com/javafx"
            xmlns:fx="http://javafx.com/fxml"
            fx:controller="ChatApp.ChatAppController"
            prefHeight="600.0" prefWidth="800.0">

    <!-- Connection Panel -->
    <VBox fx:id="connectPanel" spacing="15" alignment="CENTER" style="-fx-padding: 30;" AnchorPane.topAnchor="0" AnchorPane.bottomAnchor="0" AnchorPane.leftAnchor="0" AnchorPane.rightAnchor="0">
        <Label text="Trò Chuyện Với Protocol Buffers" style="-fx-font-size: 24; -fx-font-weight: bold;"/>

        <VBox spacing="10" style="-fx-border-color: #cccccc; -fx-border-radius: 5; -fx-padding: 20;" maxWidth="400">
            <Label text="Kết Nối Đến Server" style="-fx-font-size: 16; -fx-font-weight: bold;"/>

            <VBox spacing="5">
                <Label text="Tên người dùng:"/>
                <TextField fx:id="txtUsername" promptText="Nhập tên người dùng"/>
            </VBox>

            <VBox spacing="5">
                <Label text="Địa chỉ Server:"/>
                <TextField fx:id="txtServerHost" promptText="localhost"/>
            </VBox>

            <VBox spacing="5">
                <Label text="Cổng:"/>
                <TextField fx:id="txtServerPort" promptText="4444"/>
            </VBox>

            <Button fx:id="btnConnect" text="Kết Nối" style="-fx-padding: 10; -fx-font-size: 14;"/>
            <Label fx:id="lblConnectStatus" text="Chưa kết nối" style="-fx-text-fill: #999999;"/>
        </VBox>
    </VBox>

    <!-- Chat Panel -->
    <BorderPane fx:id="chatPanel" AnchorPane.topAnchor="0" AnchorPane.bottomAnchor="0" AnchorPane.leftAnchor="0" AnchorPane.rightAnchor="0">
        <top>
            <HBox spacing="10" style="-fx-padding: 10; -fx-background-color: #f0f0f0;" prefHeight="50">
                <Label fx:id="lblClient" text="👤 User" style="-fx-font-size: 14; -fx-font-weight: bold;" HBox.hgrow="ALWAYS"/>
                <Label fx:id="lblChatStatus" text="✅ Kết nối thành công" style="-fx-text-fill: #00aa00; -fx-font-weight: bold;"/>
            </HBox>
        </top>

        <center>
            <HBox spacing="10" style="-fx-padding: 10;">
                <!-- Chat Area -->
                <VBox HBox.hgrow="ALWAYS" spacing="0">
                    <Label text="💬 Trò Chuyện" style="-fx-font-size: 14; -fx-font-weight: bold;" VBox.vgrow="NEVER"/>
                    <ScrollPane fx:id="scrollPane" fitToWidth="true" VBox.vgrow="ALWAYS">
                        <VBox fx:id="chatArea" spacing="5" style="-fx-padding: 10;"/>
                    </ScrollPane>
                </VBox>

                <!-- User List Sidebar -->
                <VBox fx:id="userListContainer" spacing="5" style="-fx-border-color: #dddddd; -fx-border-width: 0 0 0 1; -fx-padding: 10;" prefWidth="150">
                    <Label text="👥 Người dùng" style="-fx-font-size: 12; -fx-font-weight: bold;"/>
                    <ListView fx:id="userListView" VBox.vgrow="ALWAYS"/>
                </VBox>
            </HBox>
        </center>

        <bottom>
            <VBox spacing="5" style="-fx-padding: 10; -fx-background-color: #f9f9f9;">
                <HBox spacing="10" prefHeight="40">
                            <TextField fx:id="txtMessage" promptText="Nhập tin nhắn..." HBox.hgrow="ALWAYS" style="-fx-padding: 8;"/>
                                    <Button fx:id="btnIcon" text="😊" style="-fx-padding: 8; -fx-font-size: 14;" />
                                    <Button fx:id="btnImage" text="🖼️" style="-fx-padding: 8; -fx-font-size: 14;"/>
                                    <Button fx:id="btnEncryptedImage" text="🔒" style="-fx-padding: 8; -fx-font-size: 14;"/>
                                    <Button fx:id="btnFile" text="📎" style="-fx-padding: 8; -fx-font-size: 14;"/>
                                    <Button fx:id="btnVoice" text="🎤" style="-fx-padding: 8; -fx-font-size: 14;"/>
                                    <Button fx:id="btnSend" text="📤 Gửi" style="-fx-padding: 8 20; -fx-font-size: 12;"/>
                </HBox>
            </VBox>
        </bottom>
    </BorderPane>

</AnchorPane>

